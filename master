    def move_category(self, direction):
        if "categories_order" not in self.categories_config:
            self.categories_config["categories_order"] = list(self.categories_config.keys())
        order = self.categories_config["categories_order"]
        selected = self.cat_tree.selection()
        if not selected:
            return
        cat = selected[0]
        idx = order.index(cat)
        new_idx = idx + direction
        if 0 <= new_idx < len(order):
            order.pop(idx)
            order.insert(new_idx, cat)
            self.refresh_categories_tree()
            self.cat_tree.selection_set(cat)
    
    def on_category_select(self, event):
        selected = self.cat_tree.selection()
        if not selected:
            return
        cat = selected[0]
        self.games_listbox.delete(0, tk.END)
        if cat in self.categories_config:
            games = self.categories_config[cat].get("order", [])
            for game in games:
                self.games_listbox.insert(tk.END, game)
    
    def add_game_to_category(self):
        selected = self.cat_tree.selection()
        if not selected:
            messagebox.showinfo("Info", "Sélectionnez d'abord une catégorie.")
            return
        cat = selected[0]
        # Proposer tous les jeux existants dans data_pbs (clé "game" de chaque entrée)
        all_games = set()
        for cmd, info in self.data_pbs.items():
            all_games.add(info.get("game", ""))
        if not all_games:
            messagebox.showinfo("Info", "Aucun jeu trouvé dans data_pbs.json. Ajoutez d'abord des PBs.")
            return
        
        dialog = tk.Toplevel(self.root)
        dialog.title("Ajouter un jeu")
        ttk.Label(dialog, text="Choisissez un jeu :").pack(padx=10, pady=5)
        var = tk.StringVar()
        combo = ttk.Combobox(dialog, textvariable=var, values=sorted(all_games), state="readonly")
        combo.pack(padx=10, pady=5)
        combo.set("")
        
        def add():
            game = var.get()
            if game and game not in self.categories_config[cat].get("order", []):
                self.categories_config[cat].setdefault("order", []).append(game)
                # Mettre à jour aussi game_order pour compatibilité
                self.game_order.setdefault(cat, []).append(game)
                self.games_listbox.insert(tk.END, game)
                self.status_var.set(f"Jeu {game} ajouté à {cat}")
            dialog.destroy()
        
        ttk.Button(dialog, text="Ajouter", command=add).pack(pady=5)
    
    def remove_game_from_category(self):
        selected_cat = self.cat_tree.selection()
        if not selected_cat:
            return
        cat = selected_cat[0]
        selection = self.games_listbox.curselection()
        if not selection:
            return
        idx = selection[0]
        game = self.games_listbox.get(idx)
        if messagebox.askyesno("Confirmation", f"Retirer {game} de la catégorie {cat} ?"):
            if cat in self.categories_config:
                games = self.categories_config[cat].get("order", [])
                if game in games:
                    games.remove(game)
            if cat in self.game_order and game in self.game_order[cat]:
                self.game_order[cat].remove(game)
            self.games_listbox.delete(idx)
            self.status_var.set(f"Jeu {game} retiré")
    
    def move_game(self, direction):
        selected_cat = self.cat_tree.selection()
        if not selected_cat:
            return
        cat = selected_cat[0]
        selection = self.games_listbox.curselection()
        if not selection:
            return
        idx = selection[0]
        games = self.categories_config[cat].get("order", [])
        new_idx = idx + direction
        if 0 <= new_idx < len(games):
            game = games.pop(idx)
            games.insert(new_idx, game)
            self.games_listbox.delete(0, tk.END)
            for g in games:
                self.games_listbox.insert(tk.END, g)
            self.games_listbox.selection_set(new_idx)
            self.game_order[cat] = games[:]
    
    def convert_dotnet_bitmap_to_png_base64(self, dotnet_b64, debug=False):
        """
        Convertit une chaîne base64 (provenant de LiveSplit) en base64 d'une image PNG.
        Si debug=True, sauvegarde les données brutes dans un fichier pour analyse.
        """
        if not dotnet_b64:
            return None

        try:
            raw_data = base64.b64decode(dotnet_b64)

            if debug:
                with open("debug_icon_raw.bin", "wb") as f:
                    f.write(raw_data)
                print(f"[DEBUG] Données brutes écrites dans debug_icon_raw.bin ({len(raw_data)} octets)")

            # --- Étape 1 : Essayer avec Pillow (si installé) ---
            try:
                from PIL import Image
                import io
                img = Image.open(io.BytesIO(raw_data))
                buffer = io.BytesIO()
                img.save(buffer, format="PNG")
                png_b64 = base64.b64encode(buffer.getvalue()).decode("ascii")
                return png_b64
            except ImportError:
                if debug:
                    print("Pillow non installé, passage à .NET")
            except Exception as e_pil:
                if debug:
                    print(f"Pillow a échoué : {e_pil}")

            # --- Étape 2 : Désérialisation .NET (si disponible) ---
            if self._dotnet_available:
                try:
                    stream = self._MemoryStream(raw_data)
                    formatter = self._BinaryFormatter()
                    obj = formatter.Deserialize(stream)

                    # Convertir l'objet en Bitmap
                    if isinstance(obj, self._Icon):
                        bmp = obj.ToBitmap()
                    elif isinstance(obj, self._Bitmap):
                        bmp = obj
                    else:
                        raise Exception(f"Type d'objet inattendu : {type(obj)}")

                    # Sauvegarder en PNG dans un MemoryStream
                    ms_out = self._MemoryStream()
                    bmp.Save(ms_out, self._ImageFormat.Png)
                    png_bytes = ms_out.ToArray()
                    png_b64 = base64.b64encode(bytearray(png_bytes)).decode("ascii")

                    # Nettoyage
                    stream.Close()
                    ms_out.Close()
                    bmp.Dispose()

                    return png_b64
                except Exception as e_dotnet:
                    if debug:
                        print(f"Désérialisation .NET échouée : {e_dotnet}")
            else:
                if debug:
                    print(".NET non disponible")

            # Si tout échoue
            return None

        except Exception as e:
            print(f"Erreur générale dans convert_dotnet_bitmap_to_png_base64 : {e}")
            return None
    
