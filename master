    def parse_duration(self, text):
        """
        Convertit une chaîne de durée en secondes (float).
        Formats acceptés : 
            - "HH:MM:SS.mmm"
            - "MM:SS.mmm"
            - "SS.mmm"
            - "SS"
        Les parties manquantes sont considérées comme nulles.
        Retourne None si le format est invalide.
        """
        if not text:
            return None
        text = text.strip().replace(',', '.')  # accepter la virgule comme séparateur décimal
        parts = text.split(':')
        try:
            if len(parts) == 3:
                h, m, s = parts
                seconds = int(h) * 3600 + int(m) * 60 + float(s)
            elif len(parts) == 2:
                m, s = parts
                seconds = int(m) * 60 + float(s)
            elif len(parts) == 1:
                seconds = float(parts[0])
            else:
                return None
            return seconds
        except ValueError:
            return None

    def parse_livesplit_time(self, t_str):
        """Convertit une chaîne de temps LiveSplit (HH:MM:SS.mmm) en secondes (float)."""
        if not t_str:
            return 0.0
        parts = t_str.split(':')
        try:
            if len(parts) == 3:
                h, m, s = parts
                return int(h) * 3600 + int(m) * 60 + float(s)
            elif len(parts) == 2:
                m, s = parts
                return int(m) * 60 + float(s)
            elif len(parts) == 1:
                return float(parts[0])
            else:
                return 0.0
        except ValueError:
            return 0.0

    def format_duration_edit(self, seconds):
        """
        Convertit un nombre de secondes en chaîne de durée lisible pour l'édition.
        Format : "HH:MM:SS.mmm" (en omettant les parties nulles si possible)
        Les millisecondes sont arrondies à 3 chiffres.
        """
        if seconds is None:
            return ""
        seconds = float(seconds)
        h = int(seconds // 3600)
        m = int((seconds % 3600) // 60)
        s = seconds % 60
        
        # Formater les secondes avec 3 décimales, sans zéros inutiles en fin
        # Mais on garde toujours au moins une décimale si nécessaire
        s_str = f"{s:.3f}".rstrip('0').rstrip('.')
        if s_str == '':
            s_str = '0'
        
        # S'assurer que les minutes ont toujours 2 chiffres si heures présentes
        if h > 0:
            return f"{h}:{m:02d}:{s_str}"
        elif m > 0:
            # Pour les minutes, on veut toujours 2 chiffres pour les minutes
            # mais on laisse les secondes avec leur format
            return f"{m:02d}:{s_str}"
        else:
            return s_str
    
