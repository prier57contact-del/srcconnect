    def refresh_categories_tree(self):
        for item in self.cat_tree.get_children():
            self.cat_tree.delete(item)
        if "categories_order" not in self.categories_config:
            self.categories_config["categories_order"] = list(self.categories_config.keys())
        order = self.categories_config["categories_order"]
        for cat in order:
            cat_data = self.categories_config.get(cat)
            if cat_data is None:
                continue
            if not isinstance(cat_data, dict):
                if isinstance(cat_data, list):
                    default_color = "#888888"
                    self.categories_config[cat] = {"color": default_color, "order": cat_data}
                    cat_data = self.categories_config[cat]
                else:
                    continue
            color = cat_data.get("color", "#888888")
            img_path = self.find_category_image(cat)
            image_status = "✅" if img_path else "❌"
            self.cat_tree.insert("", "end", text=cat, values=(color, image_status), iid=cat)
        save_json(CATEGORIES_CONFIG_FILE, self.categories_config)
    
    def add_category(self):
        name = simpledialog.askstring("Nouvelle catégorie", "Nom de la catégorie :")
        if not name:
            return
        if name in self.categories_config:
            messagebox.showerror("Erreur", "Cette catégorie existe déjà.")
            return
        color = colorchooser.askcolor(title="Choisir une couleur")[1]
        if not color:
            color = "#888888"
        self.categories_config[name] = {"color": color, "order": []}
        # Ajouter à l'ordre
        if "categories_order" not in self.categories_config:
            self.categories_config["categories_order"] = list(self.categories_config.keys())
        self.categories_config["categories_order"].append(name)
        self.game_order[name] = []  # pour compatibilité
        self.refresh_categories_tree()
        self.status_var.set(f"Catégorie {name} ajoutée")
    
    def delete_category(self):
        selected = self.cat_tree.selection()
        if not selected:
            return
        cat = selected[0]
        if messagebox.askyesno("Confirmation", f"Supprimer la catégorie {cat} ?"):
            del self.categories_config[cat]
            if cat in self.game_order:
                del self.game_order[cat]
            # Retirer de l'ordre
            if "categories_order" in self.categories_config and cat in self.categories_config["categories_order"]:
                self.categories_config["categories_order"].remove(cat)
            self.refresh_categories_tree()
            self.games_listbox.delete(0, tk.END)
            self.status_var.set(f"Catégorie {cat} supprimée")
    
