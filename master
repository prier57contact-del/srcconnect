    def delete_pb(self):
        selected = self.pb_tree.selection()
        if not selected:
            return
        cmd = selected[0]
        if cmd.startswith("game_"):
            messagebox.showinfo("Info", "Veuillez sélectionner une commande spécifique.")
            return
        if messagebox.askyesno("Confirmation", f"Supprimer la commande {cmd} ?"):
            del self.data_pbs[cmd]
            self.refresh_pb_tree()
            self.status_var.set(f"Commande {cmd} supprimée")
            
