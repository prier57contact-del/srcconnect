    def refresh_pb_tree(self):
        # Effacer tout
        for item in self.pb_tree.get_children():
            self.pb_tree.delete(item)

        # Regrouper les commandes par jeu
        games = {}
        for cmd, info in self.data_pbs.items():
            game = info.get("game", "")
            if game not in games:
                games[game] = []
            games[game].append((cmd, info))

        # Pour chaque jeu, créer un nœud parent et insérer les commandes enfants
        for game in sorted(games.keys()):
            parent_id = f"game_{game}"
            # Vérifier l'image du jeu
            img_path = self.find_image_for_game(game)
            image_status = "✅" if img_path else "❌"
            # Insérer le nœud parent (valeurs: 9 colonnes + image)
            self.pb_tree.insert("", "end", iid=parent_id, text=game, values=("", game, "", "", "", "", "", "", image_status), open=True)
            for cmd, info in sorted(games[game], key=lambda x: x[0]):
                sub = json.dumps(info.get("subcategories", {}), ensure_ascii=False) if info.get("subcategories") else ""
                include = "Oui" if info.get("include", True) else "Non"
                # Pour les enfants, on met une chaîne vide dans la colonne image
                self.pb_tree.insert(parent_id, "end", iid=cmd, values=(
                    cmd,
                    "",
                    info.get("category", ""),
                    info.get("game_id", ""),
                    info.get("category_id", ""),
                    sub,
                    info.get("leaderboard", ""),
                    info.get("multiple_runs", 1),
                    include,
                    ""  # colonne image vide pour les commandes
                ))
    
