    def edit_pb_dialog(self, new=True, cmd=None):
        dialog = tk.Toplevel(self.root)
        dialog.title("Ajouter/Modifier PB")
        dialog.geometry("900x300")

        fields = ["commande", "game", "category", "leaderboard", "game_id", "category_id", "subcategories", "multiple_runs"]
        field_labels = {
            "commande": "Titre",
            "game": "Nom du jeu",
            "category": "Catégorie",
            "leaderboard": "URL du Leaderboard",
            "game_id": "game_id",
            "category_id": "category_id",
            "subcategories": "subcategories",
            "multiple_runs": "Runs multiples"
        }

        entries = {}

        if not new and cmd:
            info = self.data_pbs[cmd]
            defaults = {field: info.get(field, "") for field in fields}
            defaults["commande"] = cmd
            include_default = info.get("include", True)
        else:
            defaults = {field: "" for field in fields}
            defaults["multiple_runs"] = 1
            include_default = True

        row = 0
        for field in fields:
            ttk.Label(dialog, text=field_labels[field]).grid(row=row, column=0, sticky=tk.W, padx=5, pady=2)

            if field == "subcategories":
                val = defaults.get(field, "")
                if isinstance(val, dict):
                    val = json.dumps(val, ensure_ascii=False)
                entry = ttk.Entry(dialog, width=50)
                entry.insert(0, val)
                entry.grid(row=row, column=1, padx=5, pady=2)
                entry.config(state='readonly')
            elif field == "multiple_runs":
                entry = ttk.Spinbox(dialog, from_=1, to=10, width=10)
                entry.delete(0, tk.END)
                entry.insert(0, str(defaults.get(field, 1)))
                entry.grid(row=row, column=1, sticky=tk.W, padx=5, pady=2)
                ttk.Label(dialog, text="(nombre d'apparitions du joueur sur le leaderbord)").grid(row=row, column=2, padx=5, pady=2, sticky=tk.W)
            elif field == "leaderboard":
                entry = ttk.Entry(dialog, width=50)
                entry.insert(0, defaults.get(field, ""))
                entry.grid(row=row, column=1, padx=5, pady=2, sticky=tk.W)
                extract_btn = ttk.Button(dialog, text="Extraire", command=lambda e=entry: self.extract_from_leaderboard(e, entries))
                extract_btn.grid(row=row, column=2, padx=5, pady=2)
                ttk.Label(dialog, text="(collez l'URL ici)").grid(row=row, column=3, padx=5, pady=2)
            elif field in ("game_id", "category_id"):
                entry = ttk.Entry(dialog, width=50)
                entry.insert(0, defaults.get(field, ""))
                entry.grid(row=row, column=1, padx=5, pady=2)
                entry.config(state='readonly')
            else:
                entry = ttk.Entry(dialog, width=50)
                entry.insert(0, defaults.get(field, ""))
                entry.grid(row=row, column=1, padx=5, pady=2)

            entries[field] = entry
            row += 1

        # Champ "include" (case à cocher)
        include_var = tk.BooleanVar(value=include_default)
        ttk.Label(dialog, text="Inclure dans le HTML").grid(row=row, column=0, sticky=tk.W, padx=5, pady=2)
        include_check = ttk.Checkbutton(dialog, variable=include_var)
        include_check.grid(row=row, column=1, sticky=tk.W, padx=5, pady=2)
        row += 1

        def save():
            data = {}
            for field in fields:
                val = entries[field].get().strip()
                if field == "multiple_runs":
                    try:
                        val = int(val)
                    except:
                        val = 1
                elif field == "subcategories" and val:
                    try:
                        val = json.loads(val)
                    except:
                        messagebox.showerror("Erreur", "Sous-catégories doit être un JSON valide")
                        return
                elif field == "subcategories" and not val:
                    val = None
                data[field] = val

            cmd_key = data.pop("commande")
            if not cmd_key:
                messagebox.showerror("Erreur", "La commande est obligatoire")
                return

            if new and cmd_key in self.data_pbs:
                messagebox.showerror("Erreur", "Cette commande existe déjà")
                return

            entry = {
                "game": data["game"],
                "category": data["category"],
                "game_id": data["game_id"],
                "category_id": data["category_id"],
                "leaderboard": data["leaderboard"],
                "include": include_var.get()
            }
            if data.get("subcategories"):
                entry["subcategories"] = data["subcategories"]
            if data.get("multiple_runs", 1) != 1:
                entry["multiple_runs"] = data["multiple_runs"]

            self.data_pbs[cmd_key] = entry
            self.refresh_pb_tree()
            dialog.destroy()
            self.status_var.set(f"PB {cmd_key} sauvegardé")

        ttk.Button(dialog, text="Sauvegarder", command=save).grid(row=row, column=0, columnspan=2, pady=10)

    def extract_from_leaderboard(self, url_entry, entries):
        url = url_entry.get().strip()
        if not url:
            messagebox.showerror("Erreur", "Veuillez entrer une URL")
            return

        try:
            # Séparer chemin et requête
            if '?' not in url:
                messagebox.showerror("Erreur", "L'URL ne contient pas le paramètre '?h='")
                return
            path_part, query_part = url.split('?', 1)

            # Extraire le game_id
            game_id = path_part.split('/')[-1]
            if not game_id:
                messagebox.showerror("Erreur", "Impossible d'extraire le game_id")
                return

            # Analyser les paramètres
            from urllib.parse import parse_qs
            query_params = parse_qs(query_part)
            x_param = query_params.get('x', [None])[0]
            if not x_param:
                messagebox.showerror("Erreur", "L'URL ne contient pas le paramètre 'x'")
                return

            # Découper le paramètre x
            parts_x = x_param.split('-')
            category_id = parts_x[0]

            subcategories = {}
            if len(parts_x) > 1:
                for sub in parts_x[1:]:
                    if '.' in sub:
                        key, val = sub.split('.', 1)
                        subcategories[key] = val

            # Mise à jour des champs : on les rend modifiables temporairement
            for field in ["game_id", "category_id", "subcategories"]:
                entries[field].config(state='normal')
                entries[field].delete(0, tk.END)

            entries["game_id"].insert(0, game_id)
            entries["category_id"].insert(0, category_id)
            if subcategories:
                entries["subcategories"].insert(0, json.dumps(subcategories, ensure_ascii=False))

            # On les repasse en lecture seule
            for field in ["game_id", "category_id", "subcategories"]:
                entries[field].config(state='readonly')

            self.status_var.set("Extraction réussie !")
        except Exception as e:
            messagebox.showerror("Erreur", f"Impossible d'extraire les informations : {str(e)}")
    
