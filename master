    def format_duration_with_precision(self, seconds, game_name=None, category_name=None):
        """
        Formate une durée avec la précision appropriée selon le jeu et la catégorie
        seconds: float (peut avoir des millisecondes)
        game_name: nom du jeu
        category_name: nom de la catégorie
        """
        if seconds is None:
            return ""
        
        precision_settings = self.get_precision_settings()
        # Construire la clé complète
        full_key = f"{game_name} - {category_name}" if game_name and category_name else None
        use_ms = precision_settings.get(full_key, False) if full_key else False
        
        if use_ms:
            h = int(seconds // 3600)
            m = int((seconds % 3600) // 60)
            s = seconds % 60
            if h > 0:
                return f"{h}h {m:02d}m {s:06.3f}s"
            elif m > 0:
                return f"{m}m {s:06.3f}s"
            else:
                return f"{s:.3f}s"
        else:
            seconds_int = int(seconds)
            h = seconds_int // 3600
            m = (seconds_int % 3600) // 60
            s = seconds_int % 60
            if h > 0:
                return f"{h}h {m:02d}m {s:02d}s"
            elif m > 0:
                return f"{m}m {s:02d}s"
            else:
                return f"{s}s"
    
    def normalize_date(self, date_str):
        """Convertit une date en format ISO (YYYY-MM-DD) si possible, sinon retourne None."""
        if not date_str:
            return None
        # Si déjà au format ISO, on valide
        try:
            datetime.strptime(date_str, "%Y-%m-%d")
            return date_str
        except ValueError:
            pass
        # Essayer d'autres formats courants
        for fmt in ("%d/%m/%Y", "%m/%d/%Y", "%Y-%m-%d %H:%M:%S"):
            try:
                dt = datetime.strptime(date_str, fmt)
                return dt.strftime("%Y-%m-%d")
            except ValueError:
                continue
        return None
    
